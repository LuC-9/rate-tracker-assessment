# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Database
DB_NAME=rate_tracker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Ingestion
INGEST_API_TOKEN=dev-ingest-token
SEED_DATA_PATH=/app/rates_seed.parquet
SEED_ON_STARTUP=true
INGESTION_BATCH_SIZE=5000
INGESTION_SCHEDULE_SECONDS=1800

# Optional live HTTP ingestion source
# INGESTION_SOURCE_URL=https://example.com/rates/sample

# Frontend CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cache
CACHE_LATEST_TTL=300

# Logging
LOG_FORMAT=json

# Environment validation
# Fail fast on startup when required vars are missing (see backend/rate_tracker/settings.py)
REQUIRE_ENV_VALIDATION=true
